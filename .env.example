# Service
PORT=3007
HOST=0.0.0.0

# Local development defaults
# Set PLUGIN_MODE=true when running behind the host platform iframe.
PLUGIN_MODE=false
APK_REBUILDER_UI_MODE=standalone
STRICT_TOOLCHAIN=false
STRICT_REDIS=false

# Platform integration
# For local standalone development, keep these on localhost.
MAIN_API_URL=http://127.0.0.1:8091
PLUGIN_NAME=apk-rebuilder
PLUGIN_ID=apk-rebuilder
HOST_API_BASE=http://127.0.0.1:8091
HOST_AUTH_TIMEOUT_MS=5000
HOST_PERMISSION_CACHE_TTL_MS=30000
HOST_AUTH_DEBUG=false
HOST_AUTH_ROLE_FALLBACK=false

# Reverse proxy upstreams (used by deploy/nginx-entrypoint-apk-rebuilder.sh)
APP_API_1_URL=http://127.0.0.1:8091
# APP_API_2_URL=http://127.0.0.1:8092

# Optional HS256 verification
PLUGIN_TOKEN_SECRET=

# Local debugging auth for /api/* protected routes
API_KEY=dev-api-key
AUTH_TOKEN=dev-api-key

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT_MS=8000
REDIS_CONNECT_RETRY_DELAY_MS=500

# Toolchain fallback
TOOLS_ROOT=./tools
TOOLCHAIN_FALLBACK_LOCAL=true
